<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.web.WebView?>
<?import fr.inria.corese.demo.view.TopBar?>

<BorderPane fx:id="mainBorderPane" xmlns:fx="http://javafx.com/javafx/8.0.171"
            xmlns="http://javafx.com/javafx"
            fx:controller="fr.inria.corese.demo.controller.QueryViewController">

    <!-- Top bar -->
    <top>
        <TopBar fx:id="topBar"/>
    </top>

    <!-- Center: Main SplitPane -->
    <center>
        <SplitPane fx:id="mainSplitPane" orientation="VERTICAL">
            <items>
                <!-- Top: Editor Container -->
                <StackPane fx:id="editorContainer"/>
                
                <!-- Bottom: Results TabPane -->
                <TabPane fx:id="resultsTabPane">
                    <tabs>
                        <Tab fx:id="tableTab" text="Table" closable="false">
                            <content>
                                <TableView fx:id="resultTable"/>
                            </content>
                        </Tab>
                        <Tab fx:id="graphTab" text="Graph" closable="false">
                            <content>
                                <WebView fx:id="graphView"/>
                            </content>
                        </Tab>
                        <Tab fx:id="textTab" text="Text" closable="false">
                            <content>
                                <BorderPane>
                                    <top>
                                        <HBox spacing="10" alignment="CENTER_LEFT">
                                            <ComboBox fx:id="xmlFormatComboBox" prefWidth="120"/>
                                            <Button fx:id="copyXmlButton" text="Copy"/>
                                        </HBox>
                                    </top>
                                    <center>
                                        <TextArea fx:id="xmlResultTextArea" wrapText="true"/>
                                    </center>
                                </BorderPane>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>
            </items>
        </SplitPane>
    </center>
</BorderPane>
