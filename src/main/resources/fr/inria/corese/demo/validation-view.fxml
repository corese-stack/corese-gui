<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import fr.inria.corese.demo.view.TopBar?>

<BorderPane xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="fr.inria.corese.demo.controller.ValidationViewController"
    prefHeight="600.0" prefWidth="800.0"
    fx:id="mainBorderPane">

    <top>
        <TopBar fx:id="topBar" />
    </top>

    <center>
        <SplitPane fx:id="mainSplitPane" orientation="VERTICAL">
            <items>
                <StackPane fx:id="editorContainer" minHeight="150.0" />

                <SplitPane fx:id="resultsSplitPane">
                    <items>
                        <TabPane fx:id="resultsTabPane" tabClosingPolicy="UNAVAILABLE">
                            <tabs>
                                <Tab fx:id="tableTab" text="Table" />
                                <Tab fx:id="graphTab" text="Graph" />
                                <Tab fx:id="textTab" text="Text" />  
                            </tabs>
                        </TabPane>
                    </items>
                </SplitPane>
            </items>
        </SplitPane>
    </center>

</BorderPane>