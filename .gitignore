# =======================================
#   Java / Maven / Gradle .gitignore
#   Compatible multi-IDE & multi-build
# =======================================

### === Java ===
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
*.log

# JavaFX cache
javafx-*.properties

### === Maven ===
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/
!/.mvn/wrapper/maven-wrapper.jar

### === Gradle ===
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/**/build/

### === IDEs ===

# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# Eclipse
.classpath
.project
.settings/
.factorypath
bin/

# VS Code
.vscode/
!.vscode/settings.json

# NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

### === System Files ===
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

### === Environment / Secrets ===
.env
.venv/
env/
.env.local
*.key
*.pem
*.crt

### === Logs ===
logs/
log/
*.log
*.logs

### === Temporary / Backup Files ===
*.orig
*.bak
*.swp
*~
*.tmp
*.cache
tmp/
.cache/

### === Project-specific ===
graph-context.properties
